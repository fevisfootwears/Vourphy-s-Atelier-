{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Footwear Product",
      "description": "Details of footwear items available in the atelier.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "tag": { "type": "string" },
        "description": { "type": "string" },
        "inventory": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "category", "price", "image"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Record of a purchase transaction.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "customerId", "productIds", "totalAmount", "status", "createdAt"]
    },
    "SiteBrandingAsset": {
      "title": "Branding Asset",
      "description": "A single branding visual (logo or hero).",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteAsset": {
      "title": "Site Asset",
      "description": "A categorized visual asset for specific site sections (Artisan, Bespoke, Journal).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string", "enum": ["artisan", "bespoke", "journal"] },
        "title": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "category"]
    },
    "Marketer": {
      "title": "Marketer Identity",
      "description": "Record of a registered marketing associate.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "registeredAt"]
    },
    "ReferralLead": {
      "title": "Referral Lead",
      "description": "Record of a customer inquiry generated by a marketer referral.",
      "type": "object",
      "properties": {
        "marketerUsername": { "type": "string" },
        "clientSession": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["with_marketer", "no_marketer"] }
      },
      "required": ["timestamp", "type"]
    }
  },
  "firestore": {
    "/referralLeads/{leadId}": {
      "schema": "ReferralLead",
      "description": "Tracking for customer-to-producer WhatsApp referrals."
    },
    "/marketers/{marketerId}": {
      "schema": "Marketer",
      "description": "List of registered marketing associates."
    },
    "/branding/{assetId}": {
      "schema": "SiteBrandingAsset",
      "description": "Global branding assets like 'logo' and 'hero'."
    },
    "/siteAssets/{assetId}": {
      "schema": "SiteAsset",
      "description": "Categorized assets for Artisan, Bespoke, and Journal sections."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of footwear products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order records."
    }
  }
}
